generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Precedence {
  primary
  secondary
}

model Contact {
  id Int @id @default(autoincrement())
  email String?
  phone_no String?
  LinkedId Int?
  LinkedPrecedence Precedence
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}
